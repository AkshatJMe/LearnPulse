# Cloudanary config
CLOUD_NAME=your-cloudinary-cloud-name
API_KEY=your-cloudinary-api-key
API_SECRET=your-cloudinary-api-secret


DATABASE_URL=mongodb://localhost:27017/learnpulse

JWT_SECRET=your-jwt-secret-key-minimum-32-characters
FOLDER_NAME=LearnPulse

# Email Configuration (REQUIRED for OTP/signup to work)
# Option 1: Gmail (use App Password, not regular password)
# MAIL_HOST=smtp.gmail.com
# MAIL_USER=your-email@gmail.com
# MAIL_PASS=your-16-character-app-password

# Option 2: Mailtrap (recommended for testing)
# MAIL_HOST=smtp.mailtrap.io
# MAIL_USER=your-mailtrap-username
# MAIL_PASS=your-mailtrap-password

# Choose one option and uncomment:
MAIL_HOST=smtp.gmail.com
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password

PORT=4000

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Razorpay Configuration (optional - for payments)
RAZORPAY_KEY=your-razorpay-key
RAZORPAY_SECRET=your-razorpay-secret

# Stripe Configuration (optional - for payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
PAYMENTS_MOCK=true
