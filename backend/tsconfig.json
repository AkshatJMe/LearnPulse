{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "rootDir": "src",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["seed.ts", "node_modules"],
  "ts-node": {
    "esm": true,
    "experimentalEsm": true,
    "moduleResolution": "NodeNext"
  }
}
