          "ratingAndReviews": ["ObjectId1", "ObjectId2", "ObjectId3"]
        }
      },
      "ratingandreviews": {
        "count": 33,
        "structure": {
          "user": "ObjectId -> User (Student who reviewed)",
          "rating": "Number (1-5)",
          "review": "String",
          "course": "ObjectId -> Course",
          "isApproved": "Boolean",
          "isRemoved": "Boolean",
          "createdAt": "Date (auto)",
          "updatedAt": "Date (auto)"
        },
        "example": {
          "rating": 5,
          "review": "Excellent course! The instructor explains concepts very clearly and the projects are practical and engaging.",
          "user": "ObjectId",
          "course": "ObjectId",
          "isApproved": true,
          "isRemoved": false
        }
      }
    },
    "relationships": {
      "user_to_profile": {
        "description": "Each user has exactly one profile",
        "field": "User.additionalDetails -> Profile._id"
      },
      "instructor_to_courses": {
        "description": "Each instructor created one or more courses",
        "field": "User.courses -> Array[Course._id]",
        "note": "Updated after courses are created"
      },
      "course_to_instructor": {
        "description": "Each course is taught by one instructor",
        "field": "Course.instructor -> User._id"
      },
      "course_to_category": {
        "description": "Each course belongs to one category",
        "field": "Course.category -> Category._id"
      },
      "course_to_students": {
        "description": "Each course has multiple enrolled students",
        "field": "Course.studentsEnrolled -> Array[User._id]"
      },
      "course_to_reviews": {
        "description": "Each course has multiple reviews",
        "field": "Course.ratingAndReviews -> Array[RatingAndReview._id]",
        "note": "Updated after reviews are created"
      },
      "review_to_student": {
        "description": "Each review is written by a student",
        "field": "RatingAndReview.user -> User._id"
      },
      "review_to_course": {
        "description": "Each review is about a course",
        "field": "RatingAndReview.course -> Course._id"
      }
    },
